# 证券看板 API 环境变量配置示例

# API Settings
APP_NAME=证券看板 API
APP_VERSION=0.1.0
API_PREFIX=/api/v1
DEBUG=True

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Data Provider Settings
# 从 MyFunds 项目继承 Tushare Token
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_ENABLED=True
AKSHARE_ENABLED=True

# Database Settings (Future)
DATABASE_URL=postgresql+asyncpg://securities_user:securities_pass@localhost:5432/securities_db
DATABASE_ECHO=False

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=60

# Security
SECRET_KEY=your-secret-key-change-in-production

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30

# Market Data Settings
DEFAULT_TIMEFRAME=daily

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO

# Backtest Settings (Future)
BACKTEST_ENABLED=False
