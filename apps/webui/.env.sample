# 证券看板统一环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============ 数据源配置 ============
# Tushare API Token（必需，从 https://tushare.pro 获取）
TUSHARE_TOKEN=YOUR_TUSHARE_TOKEN_HERE
TUSHARE_ENABLED=True
AKSHARE_ENABLED=True

# ============ 数据库配置 ============
# MySQL 数据库（用于历史数据）
DB_NAME=localhost
LOCAL_DB_CONN=mysql+pymysql://user:password@localhost:3306/stock
CENTOS9_DB_CONN=mysql+pymysql://stock_user:password@192.168.1.191:3306/stock
UBUNTU186_DB_CONN=mysql+pymysql://root:password@192.168.1.186:3306/stock

# PostgreSQL 配置（证券看板后端使用）
DATABASE_URL=postgresql+asyncpg://securities_user:securities_pass@localhost:5432/securities_db
DATABASE_ECHO=False

# ============ Minio 对象存储配置 ============
MINIO_ENDPOINT=192.168.1.201:19000
MINIO_ACCESS_KEY=YOUR_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=YOUR_MINIO_SECRET_KEY
MINIO_CACHE_PATH=c:\minio_cache
MINIO_SECURE=False

# ============ Redis 配置 ============
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=60

# ============ 后端 API 配置 ============
APP_NAME=证券看板 API
APP_VERSION=0.1.0
API_PREFIX=/api/v1
DEBUG=True
HOST=0.0.0.0
PORT=8011
RELOAD=True

# ============ 前端配置 ============
# Vite 开发服务器
VITE_PORT=5073
VITE_API_BASE_URL=http://localhost:8011/api/v1

# ============ 安全配置 ============
# 生产环境请使用强密码并定期更换
SECRET_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION

# ============ WebSocket 配置 ============
WS_HEARTBEAT_INTERVAL=30

# ============ 市场数据配置 ============
DEFAULT_TIMEFRAME=daily
SUPPORTED_TIMEFRAMES=1min,5min,15min,30min,60min,daily,weekly,monthly

# ============ 速率限制 ============
RATE_LIMIT_PER_MINUTE=100

# ============ 日志配置 ============
LOG_LEVEL=INFO

# ============ 其他配置 ============
BACKTEST_ENABLED=False
