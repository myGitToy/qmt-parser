# 分布式任务系统环境配置模板
# 复制此文件为 .env 并填入实际配置值

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# MySQL 配置
# =============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=myfunds
MYSQL_CHARSET=utf8mb4

# =============================================================================
# Celery 配置
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
CELERY_RESULT_EXPIRES=3600

# =============================================================================
# 任务处理配置
# =============================================================================
TASK_SLEEP_INTERVAL=0.05
TASK_MAX_RETRIES=3
TASK_BATCH_SIZE=1000
DATA_RETENTION_HOURS=24

# =============================================================================
# AKShare 数据配置
# =============================================================================
AKSHARE_MAX_ROWS=8000

# =============================================================================
# 系统配置
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/distributed_tasks.log
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5

# =============================================================================
# 网络配置
# =============================================================================
REDIS_CONNECTION_TIMEOUT=10
MYSQL_CONNECTION_TIMEOUT=30
HTTP_REQUEST_TIMEOUT=60

# =============================================================================
# 安全配置
# =============================================================================
# Redis密码（如果Redis设置了密码）
# REDIS_PASSWORD=your_redis_password

# SSL配置（如果需要）
# MYSQL_SSL_CA=/path/to/ca.pem
# MYSQL_SSL_CERT=/path/to/client-cert.pem
# MYSQL_SSL_KEY=/path/to/client-key.pem

# =============================================================================
# 性能调优配置
# =============================================================================
# Redis连接池大小
REDIS_CONNECTION_POOL_MAX_CONNECTIONS=50

# MySQL连接池配置
MYSQL_POOL_SIZE=5
MYSQL_POOL_OVERFLOW=10
MYSQL_POOL_RECYCLE=3600

# Celery性能配置
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_DISABLE_RATE_LIMITS=false

# =============================================================================
# 监控和告警配置
# =============================================================================
# 是否启用监控
MONITORING_ENABLED=true

# 告警阈值
ALERT_QUEUE_LENGTH_THRESHOLD=1000
ALERT_ERROR_RATE_THRESHOLD=0.1
ALERT_RESPONSE_TIME_THRESHOLD=5.0

# =============================================================================
# 开发和调试配置
# =============================================================================
# 调试模式
DEBUG=false

# 是否启用详细日志
VERBOSE_LOGGING=false

# 测试模式配置
TEST_MODE=false
TEST_DATA_SIZE=10
