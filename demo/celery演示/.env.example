# Celery 证券数据更新系统环境变量配置
# 请根据您的实际环境修改以下配置

# =============================================================================
# 数据库配置
# =============================================================================
# DB_NAME 数据库名称 可接受的值：aliyun, aws, localhost, centos9, ubuntu186, ubuntu191, docker_201
DB_NAME=ubuntu186

# 数据库连接字符串（根据 DB_NAME 选择）
ALIYUN_DB_CONN=mysql+pymysql://user:password@host:port/database
AWS_DB_CONN=mysql+pymysql://user:password@host:port/database
LOCAL_DB_CONN=mysql+pymysql://root:password@localhost:3306/stock
CENTOS9_DB_CONN=mysql+pymysql://user:password@192.168.1.191:3306/stock
UBUNTU186_DB_CONN=mysql+pymysql://root:q19840207@192.168.1.186:3306/stock
UBUNTU191_DB_CONN=mysql+pymysql://user:password@192.168.1.191:3306/stock
docker_201_DB_CONN=mysql+pymysql://root:password@192.168.1.201:3306/stock

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_HOST=192.168.1.201
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Celery 配置
# =============================================================================
# 任务超时时间（秒）
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# Worker 配置
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# =============================================================================
# 证券数据API配置（可选）
# =============================================================================
# Tushare API Token
TUSHARE_TOKEN=your_tushare_token_here

# 其他API配置
# AKSHARE_TOKEN=your_akshare_token_here
