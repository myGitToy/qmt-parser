# Dash资金流向应用配置文件
# 复制此文件为 .env 并填入您的API密钥

# TuShare Pro API Token
# 请在 https://tushare.pro 注册并获取token
TUSHARE_TOKEN=your_tushare_token_here

# AKShare 配置 (通常不需要token)
# AKSHARE_TOKEN=

# 应用配置
DASH_DEBUG=True
DASH_PORT=8051
DASH_HOST=127.0.0.1

# 数据库配置 (可选)
# DATABASE_URL=mysql+pymysql://user:password@localhost/myfunds

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
